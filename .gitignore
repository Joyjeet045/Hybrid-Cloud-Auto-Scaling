# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Packaging / build artifacts ----
# Anchored to the repo root (leading '/') so they never shadow real source
# directories such as nfg_diagscale/hgraph_env/env/ or .../autoscaling_v1/lib/,
# which hold the vendored HGraphScale simulator and MUST be committed.
/build/
/dist/
/develop-eggs/
/downloads/
/eggs/
/.eggs/
/parts/
/sdist/
/var/
/wheels/
*.egg-info/
*.egg
.installed.cfg

# ---- Virtual environments (repo root only) ----
/.venv/
/venv/
/env/
/ENV/

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Runtime outputs (regenerable, not source) ----
results/
checkpoint/
debug/
*.log
# Simulator packet/allocation trace dumps (written next to the lib code).
**/allocation_trace_*.csv
# Multi-GB raw trace archives (e.g. Alibaba NodeMetrics). The derived, tiny
# lib/alibaba_workload.json IS tracked; the source tarballs never are.
*.tar.gz

# ---- Local scratch / throwaway audit scripts (never published) ----
_sanity_*.json
_audit_*.py
_smoke_*.py
_ref_*.py
_strip_*.py
_star_setup.txt

# ---- Ablation experiment caches / weights (regenerable, never published) ----
# Distillation record caches and trained GCN weights for the ablation studies
# under ablations/. They are rebuilt on demand by each ablation's trainer.
ablations/**/_records_*.pkl
ablations/**/gnn_weights.pt
ablations/**/*.pt
_gnn_records_*.pkl
nfg_diagscale/decision/gnn_weights.pt
